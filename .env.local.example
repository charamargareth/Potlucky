# ============================================================
# SUPABASE
# Dapatkan dari Project Settings > API di dashboard Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# WEB PUSH (VAPID)
# Generate dengan: npx web-push generate-vapid-keys
# ============================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:kamu@contoh.com

# ============================================================
# CRON SECRET
# String acak bebas, dipakai untuk mengamankan endpoint /api/cron/reminders
# Generate misalnya dengan: openssl rand -hex 32
# ============================================================
CRON_SECRET=
